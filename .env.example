# Database
# PostgreSQL connection string (Neon recommended)
DATABASE_URL=postgresql://user:password@localhost:5432/kanban

# NextAuth / Auth.js
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-here
NEXTAUTH_SECRET=your-auth-secret-here

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_UPLOAD_PRESET=your-upload-preset

# Public URLs
# Portfolio website URL (displayed in landing page footer)
NEXT_PUBLIC_PORTFOLIO_URL=https://your-portfolio.example.com
# GitHub repository URL (displayed in landing page footer)
NEXT_PUBLIC_GITHUB_URL=https://github.com/your-username/your-repo
