    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.3",
    "lucide-react": "^1.18.0",
    "next": "^16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "pg": "^8.21.0",
    "radix-ui": "^1.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.53.0",
    "server-only": "^0.0.1",
    "shadcn": "^4.11.0",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
